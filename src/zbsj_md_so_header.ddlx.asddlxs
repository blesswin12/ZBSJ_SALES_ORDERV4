     { type: #FOR_ACTION, dataAction: 'setBilled', label: 'Mark as Billed', qualifier: 'StatusDetails_FG' },
     { type: #FOR_ACTION, dataAction: 'setNotBilled', label: 'Reverse Billing', qualifier: 'StatusDetails_FG' }
