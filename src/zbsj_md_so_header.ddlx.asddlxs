@Metadata.layer: #CORE
@UI: {
  headerInfo: { typeName: 'Sales Order', typeNamePlural: 'Sales Orders', title: { type: #STANDARD, value: 'SalesOrderId' } }
}
annotate entity ZBSJ_C_SO_HEADER with
{
   @UI.facet: [
    // 1. Parent Facet (The invisible container holding both side-by-side sections)
    { id: 'GeneralInfo', 
      purpose: #STANDARD, 
      type: #COLLECTION, 
      label: 'General Information', 
      position: 10 },

    // 2. Left Section: Sales Order Details
    { id: 'OrderDetails', 
      parentId: 'GeneralInfo', 
      purpose: #STANDARD, 
      type: #FIELDGROUP_REFERENCE, 
      label: 'Sales Order Details', 
      targetQualifier: 'OrderDetails_FG', 
      position: 10 },

    // 3. Right Section: Status Information
    { id: 'StatusDetails', 
      parentId: 'GeneralInfo', 
      purpose: #STANDARD, 
      type: #FIELDGROUP_REFERENCE, 
      label: 'Status Information', 
      targetQualifier: 'StatusDetails_FG', 
      position: 20 },

    // 4. Line Items for the child items at the bottom of the page
    { id: 'Items', 
      purpose: #STANDARD, 
      type: #LINEITEM_REFERENCE, 
      label: 'Items', 
      position: 30, 
      targetElement: '_Item' }
  ]

@UI: {
     lineItem: [{ position: 10 }],
     fieldGroup: [
       { position: 10, qualifier: 'OrderDetails_FG' },
       { type: #FOR_ACTION, dataAction: 'CreateMaterial', label: 'Create New Material', qualifier: 'OrderDetails_FG' }
     ],
     selectionField: [{ position: 10 }]
   }
  SalesOrderId;

  @UI: { lineItem: [{ position: 20 }], fieldGroup: [{ position: 20, qualifier: 'OrderDetails_FG' }], selectionField: [{ position: 20 }] }
  OrderType;

  @UI: { lineItem: [{ position: 40 }], fieldGroup: [{ position: 40, qualifier: 'OrderDetails_FG' }]}
  CompanyCode;

  @UI: { lineItem: [{ position: 50 }], fieldGroup: [{ position: 50, qualifier: 'OrderDetails_FG' }] }
  @Consumption.valueHelpDefinition: [{ entity: { name: 'ZBSJ_I_SALES_ORG_VH', element: 'SalesOrg' } }]
  SalesOrg;

  @UI: {
    lineItem: [
      { position: 60 },
      { type: #FOR_ACTION, dataAction: 'createNewCustomer', label: 'Create New Customer' }
    ],
    fieldGroup: [
      { position: 60, qualifier: 'OrderDetails_FG' },
      { type: #FOR_ACTION, dataAction: 'createNewCustomer', label: 'Create New Customer', qualifier: 'OrderDetails_FG' }
    ],
    selectionField: [{ position: 60 }]
  }
  CustomerId;

  @UI.hidden: true
  MaterialId;

  @UI: { lineItem: [{ position: 70 }], fieldGroup: [{ position: 70, qualifier: 'OrderDetails_FG' }] }
  OrderDate;

  @UI: { lineItem: [{ position: 80 }], fieldGroup: [{ position: 80, qualifier: 'OrderDetails_FG' }] }
  ReqDeliveryDate;

  @UI: { lineItem: [{ position: 90 }], fieldGroup: [{ position: 90, qualifier: 'OrderDetails_FG' }]}
  NetAmount;

  @UI: { lineItem: [{ position: 100 }], fieldGroup: [{ position: 100, qualifier: 'OrderDetails_FG' }] }
  TaxAmount;

  @UI: { lineItem: [{ position: 110 }], fieldGroup: [{ position: 110, qualifier: 'OrderDetails_FG' }] }
  GrossAmount;

  @UI.hidden: true
  Currency;

  // --- RIGHT SIDE: STATUS DETAILS ---

   @UI: { 
    lineItem: [
      { position: 130, criticality: 'OverallCriticality' }
    ], 
    fieldGroup: [
      { position: 130, criticality: 'OverallCriticality', qualifier: 'StatusDetails_FG' }
    ],
    textArrangement: #TEXT_ONLY
  }
  OverallStatus;

  @UI: {
    lineItem: [
      { position: 140, criticality: 'DeliveryCriticality' },
      { type: #FOR_ACTION, dataAction: 'setDelivered', label: 'Mark as Delivered', inline: true }
    ],
    fieldGroup: [
      { position: 140, criticality: 'DeliveryCriticality', qualifier: 'StatusDetails_FG' },
      { type: #FOR_ACTION, dataAction: 'setDelivered', label: 'Mark as Delivered', qualifier: 'StatusDetails_FG' },
      { type: #FOR_ACTION, dataAction: 'setNotDelivered', label: 'Reverse Delivery', qualifier: 'StatusDetails_FG' }
    ],
    textArrangement: #TEXT_ONLY
  }
  DeliveryStatus;

  @UI: {
   lineItem: [
